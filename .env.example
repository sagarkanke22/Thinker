# Local model server (Ollama) — required for the AI chat (Steps 19-21).
# Hand-editing logic in the Monaco code editor works WITHOUT this.
#
# Setup:
#   1. Install Ollama: https://ollama.ai/download
#   2. ollama pull qwen2.5-coder:7b   # ~4 GB
#   3. ollama serve                   # daemon on the URL below
#
# To use a different code model, just change OLLAMA_MODEL — anything
# you can `ollama pull` works.
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=qwen2.5-coder:7b

# SQLite database file
DB_PATH=./logiclive.db

# Backend server
LOGICLIVE_HOST=127.0.0.1
LOGICLIVE_PORT=8000

# Frontend dev server (Vite) — proxies /api → LOGICLIVE_HOST:PORT
FRONTEND_PORT=5173
